{
  "name": "little-harness-desktop",
  "version": "1.2.0",
  "private": true,
  "description": "Electron shell for Little Harness: a modern web UI over the Python agent sidecar.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "smoke": "electron . --smoke",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^38.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dev.littleharness.app",
    "productName": "Little Harness",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist/LittleHarness",
        "to": "sidecar"
      },
      {
        "from": "../packaging/littleharness.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "../packaging/littleharness.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "LittleHarness-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "armand0e",
      "repo": "little-model-harness"
    }
  }
}
